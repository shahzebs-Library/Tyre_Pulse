# Copy to .env.local — never commit .env.local
#
# ⚠️  SECURITY: every VITE_* variable is bundled into the public browser JS.
#     NEVER put a secret (Anthropic key, service_role key, SMTP password) in a
#     VITE_* var — it would be visible to every visitor.
#
# Only public, RLS-protected values belong here:
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── AI / Anthropic key — SERVER SIDE ONLY ────────────────────────────────────
# Do NOT add VITE_ANTHROPIC_API_KEY. All AI runs through the `chat-ai` Supabase
# Edge Function, which reads ANTHROPIC_API_KEY from Edge Function secrets:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   # or: Dashboard → Edge Functions → Manage secrets → add ANTHROPIC_API_KEY
#
# (The same applies to send-email's SMTP creds and SUPABASE_SERVICE_ROLE_KEY —
#  Edge Function secrets only, never VITE_*.)
