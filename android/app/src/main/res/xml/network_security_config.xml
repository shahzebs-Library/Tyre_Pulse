<?xml version="1.0" encoding="utf-8"?>
<!--
  Production traffic is HTTPS only. Cleartext is permitted ONLY to the local
  development Go API on the emulator loopback (10.0.2.2) and localhost, so a
  dev build can reach a locally-running backend. Release builds talking to a
  real API must use HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
