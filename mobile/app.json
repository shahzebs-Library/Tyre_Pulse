{
  "expo": {
    "name": "TyrePulse Inspector",
    "slug": "tyrepulse-inspector",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shahzebrahman.tyrepulseinspector",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TyrePulse tags each inspection with your current location so fleet managers can see where tyre checks were performed."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.shahzebrahman.tyrepulseinspector",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#16a34a",
          "defaultChannel": "tyrepulse"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "TyrePulse needs camera access to photograph tyres during inspections."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TyrePulse needs photo access to attach images to tyre inspections."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TyrePulse tags each inspection with your current location so fleet managers can see where tyre checks were performed.",
          "locationWhenInUsePermission": "TyrePulse tags each inspection with your current location so fleet managers can see where tyre checks were performed.",
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24,
            "ndkVersion": "27.1.12297006"
          }
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "shah-profile",
          "project": "javascript-nextjs",
          "url": "https://de.sentry.io"
        }
      ],
      "./plugins/withLargeScreen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "tyrepulse-inspector",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3ed4e62f-e91f-4c78-b1eb-9b7310c08255",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3ed4e62f-e91f-4c78-b1eb-9b7310c08255"
      },
      "supabaseUrl": "https://jhssdmeruxtrlqnwfksc.supabase.co",
      "supabaseAnonKey": "sb_publishable_UDEH7EeHA9S5-NNu4T-9Ug_R60IinrW",
