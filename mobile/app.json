{
  "expo": {
    "name": "TyrePulse Inspector",
    "slug": "tyrepulse-inspector",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f5f1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shahzebrahman.tyrepulseinspector"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.shahzebrahman.tyrepulseinspector",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "TyrePulse needs camera access to photograph tyres during inspections."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TyrePulse needs photo access to attach images to tyre inspections."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24,
            "ndkVersion": "27.1.12297006"
          }
        }
      ]
    ],
    "experiments": {
