# TyrePulse Go API — server-only configuration. NEVER commit real values.
# Copy to backend/.env for local dev (docker-compose loads it).

# Runtime
APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info

# Postgres (Phase A: the existing Supabase Postgres connection string, server-only).
# For local docker-compose dev, point at the bundled postgres service instead.
# Supabase: Project Settings -> Database -> Connection string (use the pooler).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tyrepulse?sslmode=disable

# Supabase JWT secret (Project Settings -> API -> JWT Secret). Used to verify
# the HS256 signature of Supabase-issued access tokens. Server-only.
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# CORS allow-list (comma-separated origins of the web app).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Limits / timeouts
RATE_LIMIT_PER_MIN=120
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=15s

# Object storage (Phase A: Supabase private buckets; later MinIO/S3).
# STORAGE_PROVIDER=supabase
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Redis (background jobs / cache).
# REDIS_URL=redis://localhost:6379/0
