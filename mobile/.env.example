# Copy to .env and fill in your values (same as the web app)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Go API base URL (optional; backend migration). Leave blank until the mobile
# module is cut over — the apiClient throws "not_configured" while unset and
# the app keeps using Supabase directly. e.g. http://10.0.2.2:8080
EXPO_PUBLIC_API_BASE_URL=
