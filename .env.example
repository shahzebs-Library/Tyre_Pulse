# ─────────────────────────────────────────────────────────────────────────────
# TYRE PULSE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Go API (optional; backend migration) ──────────────────────────────────────
# Base URL of the TyrePulse Go API. Leave blank until a module is migrated —
# the apiClient throws "not_configured" while unset, and pages continue to use
# Supabase directly. e.g. http://localhost:8080
VITE_API_BASE_URL=

# ── AI (local dev only — not needed in production) ────────────────────────────
# In production, AI calls route through the chat-ai Edge Function (server-side key).
# Only uncomment locally if you want to bypass the edge function during development.
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE EDGE FUNCTION SECRETS
# Set in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# These stay server-side — never put them in .env or Vercel env vars.
# ─────────────────────────────────────────────────────────────────────────────
#
# ANTHROPIC_API_KEY=sk-ant-...          # Used by chat-ai function
# OPENAI_API_KEY=sk-...                 # Used by generate-embedding function
# RESEND_API_KEY=re_...                 # Used by send-email function
# FROM_EMAIL=reports@yourdomain.com     # Sender address for email reports
#
# Supabase injects automatically (no action needed):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
