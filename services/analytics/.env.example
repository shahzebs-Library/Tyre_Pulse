# Supabase Postgres connection string (use the pooled connection, port 6543,
# for serverless platforms; direct 5432 works for long-lived containers).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Shared secret required in the x-service-key header on every /v1 request.
# Generate with: openssl rand -hex 32
ANALYTICS_SERVICE_KEY=replace-with-a-long-random-secret

# Comma-separated CORS origins. Leave empty when only server-side callers
# (Supabase edge functions) talk to this service - which is the recommended setup.
ALLOWED_ORIGINS=

LOG_LEVEL=INFO
